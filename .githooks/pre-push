#!/usr/bin/env bash
set -euo pipefail

# ============================================================================
# PRE-PUSH HOOK: Fast validation of pushed changes
# ============================================================================
# This hook reads stdin to detect which files are being pushed, then runs
# only the relevant checks on changed files. Full-repo validation happens in CI.
#
# Performance: Targets <1s for typical warm pushes by:
#   - Parsing stdin to detect exactly which files changed
#   - Running checks only on changed files (not the whole repo)
#   - Skipping irrelevant checks (e.g. no .cs files changed → skip C# guards)
#
# Last-resort checks performed (when relevant files change):
#   0. Safe cleanup of gitignored hook-output artifacts
#   1. #region guard on changed C# files
#
# Formatting, spelling, docs, EOL, meta, license-year, and regression-suite
# checks belong in npm run agent:preflight, npm run validate:prepush, and CI.
# This hook is a last-resort gate and must stay fast on native developer
# machines.
#
# To skip in emergencies: git push --no-verify
#   (CI will still validate all checks)
# ============================================================================

# ---- Changed-file detection from stdin ----
# Pre-push stdin format: <local-ref> <local-sha> <remote-ref> <remote-sha>
# Multiple lines possible when pushing multiple refs at once.
ZERO_SHA="0000000000000000000000000000000000000000"
CS_GREP_PATHSPEC_THRESHOLD=128
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$REPO_ROOT"
HAS_REFS=false
ALL_CHANGED_FILES=()
CS_SCAN_SHAS=()
CS_SCAN_PATHS=()

array_contains_exact() {
  local needle="$1"
  shift || true
  local item
  for item in "$@"; do
    if [[ "$item" == "$needle" ]]; then
      return 0
    fi
  done
  return 1
}

collect_hook_artifact_candidates() {
  local repo_root="$1"
  local hooks_dir="$repo_root/.githooks"
  local hook_path
  local hook
  local ext
  local candidate

  if [ ! -d "$hooks_dir" ]; then
    return 0
  fi

  for hook_path in "$hooks_dir"/*; do
    [ -f "$hook_path" ] || continue
    hook="${hook_path##*/}"
    case "$hook" in
      *.sample|*.txt|*.log|*.out|*.err|*.tmp)
        continue
        ;;
    esac
    if [[ "$hook" == *.* ]]; then
      hook="${hook%.*}"
    fi

    for ext in txt log out err tmp; do
      candidate="$repo_root/$hook.$ext"
      [ -f "$candidate" ] || continue
      printf '%s\n' "$hook.$ext"

      candidate="$hooks_dir/$hook.$ext"
      [ -f "$candidate" ] || continue
      printf '%s\n' ".githooks/$hook.$ext"
    done
  done
}

clean_gitignored_hook_artifacts() {
  local repo_root="$1"
  local rel
  local absolute
  local ignored=()
  local unignored=()
  local errors=()
  local unique=()
  local check_exit

  while IFS= read -r rel; do
    [ -n "$rel" ] || continue
    if ! array_contains_exact "$rel" "${unique[@]}"; then
      unique+=("$rel")
    fi
  done < <(collect_hook_artifact_candidates "$repo_root")

  if [ ${#unique[@]} -eq 0 ]; then
    return 0
  fi

  for rel in "${unique[@]}"; do
    check_exit=0
    git -C "$repo_root" check-ignore -q -- "$rel" || check_exit=$?
    case "$check_exit" in
      0)
        ignored+=("$rel")
        ;;
      1)
        unignored+=("$rel")
        ;;
      *)
        errors+=("$rel (git check-ignore exit $check_exit)")
        ;;
    esac
  done

  if [ ${#ignored[@]} -gt 0 ]; then
    echo "Pre-push: removing stray gitignored hook artifact file(s)..."
    for rel in "${ignored[@]}"; do
      absolute="$repo_root/$rel"
      rm -f -- "$absolute"
      echo "  removed: $rel"
    done
  fi

  if [ ${#unignored[@]} -gt 0 ] || [ ${#errors[@]} -gt 0 ]; then
    echo "Pre-push checks FAILED."
    echo "Stray hook-output artifact file(s) matched the cleanup pattern but were not safe to auto-delete:"
    for rel in "${unignored[@]}"; do
      echo "  not gitignored: $rel"
    done
    for rel in "${errors[@]}"; do
      echo "  check failed: $rel"
    done
    echo "Add the artifact pattern to .gitignore or remove the stale file, then retry."
    return 1
  fi

  return 0
}

add_changed_file() {
  local file="$1"
  if [[ -z "$file" ]]; then
    return 0
  fi

  ALL_CHANGED_FILES+=("$file")
}

add_cs_scan_path() {
  local sha="$1"
  local file="$2"

  [[ "$file" =~ \.cs$ ]] || return 0

  CS_SCAN_SHAS+=("$sha")
  CS_SCAN_PATHS+=("$file")
}

write_agent_preflight_path_list() {
  local path_list
  path_list=$(git rev-parse --git-path pre-push-agent-preflight-paths.bin 2>/dev/null || printf '%s' ".git/pre-push-agent-preflight-paths.bin")

  if [ "$#" -gt 0 ]; then
    # NUL-delimit so even unusual filenames survive the handoff to PowerShell.
    printf '%s\0' "$@" > "$path_list"
  else
    : > "$path_list"
  fi

  printf '%s\n' "$path_list"
}

print_agent_preflight_fix_hint() {
  local path_list
  path_list=$(write_agent_preflight_path_list "$@")

  echo "Automated recovery (path-scoped):"
  echo "  npm run agent:preflight:fix -- -PathList \"$path_list\""
  echo "Then commit generated fixes and push again."
}

collect_changed_files() {
  local scan_sha="$1"
  local file
  while IFS= read -r -d '' file; do
    add_changed_file "$file"
    add_cs_scan_path "$scan_sha" "$file"
  done
}

clean_gitignored_hook_artifacts "$REPO_ROOT"

while read -r _local_ref local_sha _remote_ref remote_sha; do
  # Skip delete pushes (local_sha is all zeros)
  if [ "$local_sha" = "$ZERO_SHA" ]; then
    continue
  fi
  HAS_REFS=true

  if [ "$remote_sha" = "$ZERO_SHA" ]; then
    # New branch: compare against default branch merge-base
    merge_base=$(git merge-base main "$local_sha" 2>/dev/null || echo "")
    if [ -n "$merge_base" ]; then
      collect_changed_files "$local_sha" < <(git diff --name-only -z --diff-filter=ACMRTUXB "$merge_base".."$local_sha" 2>/dev/null || true)
    else
      # No merge-base (orphan branch or no main): compare against the full tree.
      collect_changed_files "$local_sha" < <(git ls-tree -r -z --name-only "$local_sha" 2>/dev/null || true)
    fi
  else
    # Normal push: diff between remote and local
    collect_changed_files "$local_sha" < <(git diff --name-only -z --diff-filter=ACMRTUXB "$remote_sha".."$local_sha" 2>/dev/null || true)
  fi
done

# If no refs to push (delete-only) or stdin was empty (no-op), skip all checks
if [ "$HAS_REFS" = "false" ] || [ ${#ALL_CHANGED_FILES[@]} -eq 0 ]; then
  echo "No files changed in push, skipping checks."
  exit 0
fi

CHANGED_COUNT=${#ALL_CHANGED_FILES[@]}
echo "Pre-push: checking $CHANGED_COUNT changed file(s)..."

HOOK_FAILED=0

run_fast_checks() {
  # Check for #region directives (only in changed .cs files)
  if [ ${#CS_SCAN_PATHS[@]} -gt 0 ]; then
    echo "Checking for forbidden #region directives..."
    REGION_VIOLATIONS=""
    local unique_shas=()
    local sha
    local index
    local cs_paths
    local literal_paths
    local matches
    local match_line
    local match_file
    local match_prefix
    local match_path
    local match_text
    local grep_output
    local grep_exit

    for sha in "${CS_SCAN_SHAS[@]}"; do
      if ! array_contains_exact "$sha" "${unique_shas[@]}"; then
        unique_shas+=("$sha")
      fi
    done

    for sha in "${unique_shas[@]}"; do
      cs_paths=()
      for index in "${!CS_SCAN_PATHS[@]}"; do
        if [[ "${CS_SCAN_SHAS[$index]}" == "$sha" ]]; then
          cs_paths+=("${CS_SCAN_PATHS[$index]}")
        fi
      done

      [ ${#cs_paths[@]} -gt 0 ] || continue

      if [ ${#cs_paths[@]} -le "$CS_GREP_PATHSPEC_THRESHOLD" ]; then
        literal_paths=()
        for index in "${!cs_paths[@]}"; do
          literal_paths+=(":(literal)${cs_paths[$index]}")
        done

        grep_exit=0
        matches=$(git grep -H -n -i -E '^[[:space:]]*#[[:space:]]*(region|endregion)' "$sha" -- "${literal_paths[@]}" 2>/dev/null) || grep_exit=$?
        case "$grep_exit" in
          0)
            REGION_VIOLATIONS+="$matches"$'\n'
            ;;
          1)
            ;;
          *)
            echo "git grep failed while scanning pushed C# files for #region directives (exit $grep_exit)."
            return 1
            ;;
        esac
        continue
      fi

      grep_output=$(git rev-parse --git-path "pre-push-region-grep.$$.bin")
      rm -f -- "$grep_output"
      grep_exit=0
      git grep -z -H -n -i -E '^[[:space:]]*#[[:space:]]*(region|endregion)' "$sha" -- '*.cs' > "$grep_output" 2>/dev/null || grep_exit=$?
      case "$grep_exit" in
        0)
          match_prefix="${sha}:"
          while IFS= read -r -d '' match_file && IFS= read -r -d '' match_line && IFS= read -r match_text; do
            match_path="${match_file#$match_prefix}"
            [ "$match_path" != "$match_file" ] || continue
            if array_contains_exact "$match_path" "${cs_paths[@]}"; then
              REGION_VIOLATIONS+="${match_path}:${match_line}:${match_text}"$'\n'
            fi
          done < "$grep_output"
          ;;
        1)
          ;;
        *)
          rm -f -- "$grep_output"
          echo "git grep failed while scanning pushed C# files for #region directives (exit $grep_exit)."
          return 1
          ;;
      esac
      rm -f -- "$grep_output"
    done
    REGION_VIOLATIONS="${REGION_VIOLATIONS%$'\n'}"
    if [ -n "$REGION_VIOLATIONS" ]; then
      echo ""
      echo "=== Error: C# regions (#region/#endregion) are forbidden ==="
      echo "$REGION_VIOLATIONS" | head -50
      echo ""
      echo "Remove all #region and #endregion directives before pushing."
      echo ""
      return 1
    fi
    echo "✓ No #region directives found"
  fi

  return 0
}

run_fast_checks || HOOK_FAILED=1

# ============================================================================
# FINAL RESULT
# ============================================================================
if [ $HOOK_FAILED -ne 0 ]; then
  echo ""
  echo "Pre-push checks FAILED."
  print_agent_preflight_fix_hint "${ALL_CHANGED_FILES[@]}"
  echo "To skip in emergencies: git push --no-verify (CI will still validate)"
  exit 1
fi

echo ""
echo "Pre-push checks complete. Push proceeding..."
